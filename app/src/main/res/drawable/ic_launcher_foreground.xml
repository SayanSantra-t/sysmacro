<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Pulse Ring 3 (Outer fading) -->
    <path
        android:pathData="M 54,24 A 30,30 0 1,1 53.99,24 Z"
        android:strokeColor="#1F00FF88"
        android:strokeWidth="1.5"
        android:fillColor="#00000000" />

    <!-- Pulse Ring 2 -->
    <path
        android:pathData="M 54,34 A 20,20 0 1,1 53.99,34 Z"
        android:strokeColor="#4A00FF88"
        android:strokeWidth="2.5"
        android:fillColor="#00000000" />

    <!-- Seismic Target Wave Pattern -->
    <path
        android:pathData="M 28,54 L 38,54 L 42,40 L 48,68 L 52,30 L 56,78 L 60,46 L 64,54 L 80,54"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="28"
                android:startY="54"
                android:endX="80"
                android:endY="54"
                android:type="linear">
                <item android:color="#00FF88" android:offset="0.0" />
                <item android:color="#00E5FF" android:offset="0.5" />
                <item android:color="#FF3D00" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Center active target indicator -->
    <path
        android:pathData="M 54,49 A 5,5 0 1,1 53.99,49 Z"
        android:fillColor="#FF3D00" />

</vector>
